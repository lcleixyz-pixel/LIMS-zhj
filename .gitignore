# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# PHP / CakePHP legacy runtime
**/tmp/cache/**
**/tmp/logs/**
**/tmp/sessions/**
**/tmp/tests/**
!**/tmp/**/.gitkeep

# CakePHP legacy uploads (keep directory structure only)
**/webroot/files/**/*
!**/webroot/files/**/.gitkeep
**/webroot/schema/*.bak

# ThinkPHP jewelry-qms runtime and uploads
jewelry-qms/vendor/
jewelry-qms/runtime/*
!jewelry-qms/runtime/.gitignore
jewelry-qms/public/uploads/*
!jewelry-qms/public/uploads/.gitkeep

# Local config overrides (never commit secrets)
**/Config/database.local.php
.env
.env.*

# Logs and debug
**/error_log
**/debug.log
**/*.log

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# Node (if any)
node_modules/
